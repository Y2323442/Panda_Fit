{
  "buildCommand": "flutter build web --base-href '/'",
  "installCommand": "pip install -r trainquest_backend_a/requirements.txt",
  "outputDirectory": "build/web",
  "functions": {
    "trainquest_backend_a/app.py": {
      "runtime": "python3.11"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "trainquest_backend_a/app.py"
    },
    {
      "source": "/(.*)",
      "destination": "build/web/index.html"
    }
  ]
}