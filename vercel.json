{
  "buildCommand": "flutter build web --base-href '/'",
  "installCommand": "pip install -r api/requirements.txt",
  "outputDirectory": "build/web",
  "functions": {
    "api/app.py": {
      "runtime": "python3.11"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/app.py"
    },
    {
      "source": "/:path*",
      "destination": "/build/web/index.html"
    }
  ]
}