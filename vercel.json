{
  "buildCommand": "flutter build web --base-href '/'",
  "installCommand": "pip install -r trainquest_backend_a/requirements.txt",
  "outputDirectory": "build/web",

  "functions": {
    "api/index.py": {
      "runtime": "python3.11"
    }
  },

  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/:path*",
      "destination": "/build/web/index.html"
    }
  ]
}